<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dobot_me6">
  <xacro:arg name="control_mode" default="fake"/>
  <xacro:property name="control_mode_value" value="$(arg control_mode)"/>

  <xacro:macro name="simple_inertial" params="mass ixx iyy izz">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${ixx}" ixy="0" ixz="0" iyy="${iyy}" iyz="0" izz="${izz}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_link" params="name radius length mass color">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 ${length / 2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
        <material name="${color}"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${length / 2.0}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
      </collision>
      <xacro:simple_inertial mass="${mass}" ixx="0.01" iyy="0.01" izz="0.01"/>
    </link>
  </xacro:macro>

  <xacro:macro name="box_link" params="name x y z mass color">
    <link name="${name}">
      <visual>
        <origin xyz="${x / 2.0} 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${x} ${y} ${z}"/>
        </geometry>
        <material name="${color}"/>
      </visual>
      <collision>
        <origin xyz="${x / 2.0} 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${x} ${y} ${z}"/>
        </geometry>
      </collision>
      <xacro:simple_inertial mass="${mass}" ixx="0.01" iyy="0.01" izz="0.01"/>
    </link>
  </xacro:macro>

  <material name="dobot_white">
    <color rgba="0.92 0.94 0.96 1.0"/>
  </material>
  <material name="dobot_blue">
    <color rgba="0.0 0.43 0.78 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.16 0.17 0.18 1.0"/>
  </material>

  <link name="world"/>
  <xacro:cylinder_link name="base_link" radius="0.105" length="0.110" mass="2.0" color="dark_grey"/>
  <xacro:box_link name="shoulder_link" x="0.060" y="0.110" z="0.245" mass="1.5" color="dobot_white"/>
  <xacro:box_link name="upper_arm_link" x="0.280" y="0.075" z="0.075" mass="1.4" color="dobot_blue"/>
  <xacro:box_link name="forearm_link" x="0.250" y="0.065" z="0.065" mass="1.1" color="dobot_white"/>
  <xacro:cylinder_link name="wrist_1_link" radius="0.045" length="0.085" mass="0.5" color="dark_grey"/>
  <xacro:cylinder_link name="wrist_2_link" radius="0.040" length="0.075" mass="0.4" color="dobot_white"/>
  <xacro:cylinder_link name="wrist_3_link" radius="0.035" length="0.065" mass="0.3" color="dark_grey"/>
  <link name="tool0"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.110" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="80" velocity="1.2"/>
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.210" rpy="0 1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.3562" upper="2.3562" effort="80" velocity="1.2"/>
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.280 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.7925" upper="2.7925" effort="60" velocity="1.5"/>
  </joint>

  <joint name="joint4" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_1_link"/>
    <origin xyz="0.250 0 0" rpy="0 1.5708 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="30" velocity="2.0"/>
  </joint>

  <joint name="joint5" type="revolute">
    <parent link="wrist_1_link"/>
    <child link="wrist_2_link"/>
    <origin xyz="0 0 0.085" rpy="0 1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.3562" upper="2.3562" effort="30" velocity="2.0"/>
  </joint>

  <joint name="joint6" type="revolute">
    <parent link="wrist_2_link"/>
    <child link="wrist_3_link"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-6.2832" upper="6.2832" effort="20" velocity="2.5"/>
  </joint>

  <joint name="tool0_fixed" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.070" rpy="0 0 0"/>
  </joint>

  <ros2_control name="DobotME6System" type="system">
    <xacro:if value="${control_mode_value == 'gazebo'}">
      <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      </hardware>
    </xacro:if>
    <xacro:if value="${control_mode_value != 'gazebo'}">
      <hardware>
        <plugin>fake_components/GenericSystem</plugin>
      </hardware>
    </xacro:if>
    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint5">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint6">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <xacro:if value="${control_mode_value == 'gazebo'}">
    <gazebo>
      <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
        <parameters>$(find dobot_me6_bringup)/config/ros2_controllers.yaml</parameters>
      </plugin>
    </gazebo>
  </xacro:if>
</robot>
